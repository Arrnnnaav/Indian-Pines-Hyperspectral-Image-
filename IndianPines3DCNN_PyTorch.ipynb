   ],
   "source": [
    "kernel_size = (3, 3, 5)   # (D, H, W) — spectral dim last\n",
    "pool_size   = (1, 1, 3)   # pool only along spectral dimension\n",
    "lr          = 1e-3\n",
    "l2_param    = 1e-3\n",
    "filters_1   = 2**6        # 64\n",
    "filters_2   = 2**5        # 32\n",
    "filters_3   = 2**5        # 32\n",
    "drop_rate   = 0.35\n",
    "units_1     = 2**7        # 128\n",
    "units_2     = 2**7        # 128\n",
    "num_catg    = len(int_to_vector_dict)\n",
    "\n",
    "\n",
    "class ZeroPad3DIfNeeded(nn.Module):\n",
    "    \"\"\"\n",
    "    Equivalent of util.zero_pad_3D(cnn_model).\n",
    "    Pads the last spatial dim (W = spectral) so it is divisible by pool_size[-1].\n",
    "    The check is done dynamically in forward() — no model mutation required.\n",
    "    \"\"\"\n",
    "    def __init__(self, pool_size: tuple):\n",
    "        super().__init__()\n",
    "        self.stride = pool_size[-1]\n",
    "\n",
    "    def forward(self, x):\n",
    "        # x: (B, C, D, H, W)\n",
    "        remainder = x.shape[-1] % self.stride\n",
    "        if remainder:\n",
    "            x = F.pad(x, (0, self.stride - remainder))   # pad last dim only\n",
    "        return x\n",
    "\n",
    "\n",
    "class CNN3D(nn.Module):\n",
    "    \"\"\"\n",
    "    3-D CNN for hyperspectral image classification.\n",
    "    Input shape: (B, 1, C, patch_size, patch_size)\n",
    "                  B=batch, 1=depth channel, C=spectral bands, H=W=patch_size\n",
    "    \"\"\"\n",
    "    def __init__(self, num_classes: int, in_channels: int = 1):\n",
    "        super().__init__()\n",
    "\n",
    "        self.features = nn.Sequential(\n",
    "            # conv_1\n",
    "            nn.Conv3d(in_channels, filters_1, kernel_size=kernel_size,\n",
    "                      stride=1, padding=0),          # padding='valid'\n",
    "            nn.ReLU(),\n",
    "            # max_pool_1\n",
    "            nn.MaxPool3d(kernel_size=pool_size, stride=pool_size),\n",
    "            # zero_padding_1  — mirrors util.zero_pad_3D(cnn_model) after pool_1\n",
    "            ZeroPad3DIfNeeded(pool_size),\n",
    "\n",
    "            # conv_2\n",
    "            nn.Conv3d(filters_1, filters_2, kernel_size=kernel_size,\n",
    "                      stride=1, padding=0),\n",
    "            nn.ReLU(),\n",
    "            # max_pool_2\n",
    "            nn.MaxPool3d(kernel_size=pool_size, stride=pool_size),\n",
    "            # zero_padding_2  — mirrors util.zero_pad_3D(cnn_model) after pool_2\n",
    "            ZeroPad3DIfNeeded(pool_size),\n",
    "\n",
    "            # conv_3\n",
    "            nn.Conv3d(filters_2, filters_3, kernel_size=kernel_size,\n",
    "                      stride=1, padding=0),\n",
    "            nn.ReLU(),\n",
    "        )\n",
    "\n",
    "        # Compute flat size dynamically using a dummy forward pass\n",
    "        dummy      = torch.zeros(1, in_channels, *train_input_sub.shape[2:])\n",
    "        flat_size  = self.features(dummy).view(1, -1).shape[1]\n",
    "\n",
    "        self.classifier = nn.Sequential(\n",
    "            nn.Flatten(),\n",
    "            nn.Dropout(drop_rate),\n",
    "            nn.Linear(flat_size, units_1),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(units_1, units_2),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(units_2, num_classes),\n",
    "            # No softmax — nn.CrossEntropyLoss applies log_softmax internally\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        return self.classifier(self.features(x))\n",
    "\n",
    "\n",
    "cnn_model = CNN3D(num_classes=num_catg).to(device)\n",
    "print(cnn_model)\n",
    "total_params = sum(p.numel() for p in cnn_model.parameters() if p.requires_grad)\n",
    "print(f'\\nTrainable params: {total_params:,}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Train the Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "lr         = 1e-4\n",
    "batch_size = 2**5\n",
    "epochs     = 20\n",
    "\n",
    "# RMSprop + weight_decay replicates Keras l2 regulariser + RMSprop optimiser\n",
    "optimizer = optim.RMSprop(cnn_model.parameters(), lr=lr, weight_decay=l2_param)\n",
    "criterion = nn.CrossEntropyLoss()\n",
    "\n",
    "history = {'loss': [], 'val_loss': [], 'accuracy': [], 'val_accuracy': []}\n",
    "\n",
    "\n",
    "def run_epoch(loader, train=True):\n",
    "    cnn_model.train(train)\n",
    "    total_loss, correct, total = 0.0, 0, 0\n",
    "    with torch.set_grad_enabled(train):\n",
    "        for X_batch, y_batch in loader:\n",
    "            X_batch = X_batch.to(device)\n",
    "            y_batch = y_batch.to(device)\n",
    "            labels  = y_batch.argmax(dim=1)   # one-hot → class index\n",
    "\n",
    "            logits = cnn_model(X_batch)\n",
    "            loss   = criterion(logits, labels)\n",
    "\n",
    "            if train:\n",
    "                optimizer.zero_grad()\n",
    "                loss.backward()\n",
    "                optimizer.step()\n",
    "\n",
    "            total_loss += loss.item() * len(X_batch)\n",
    "            correct    += (logits.argmax(1) == labels).sum().item()\n",
    "            total      += len(X_batch)\n",
    "\n",
    "    return total_loss / total, correct / total\n",
    "\n",
    "\n",
    "for epoch in range(1, epochs + 1):\n",
    "    tr_loss,  tr_acc  = run_epoch(train_loader, train=True)\n",
    "    val_loss, val_acc = run_epoch(val_loader,   train=False)\n",
    "\n",
    "    history['loss'].append(tr_loss)\n",
    "    history['accuracy'].append(tr_acc)\n",
    "    history['val_loss'].append(val_loss)\n",
    "    history['val_accuracy'].append(val_acc)\n",
    "\n",
    "    print(f'Epoch {epoch:02d}/{epochs}  '\n",
    "          f'loss={tr_loss:.4f}  acc={tr_acc:.4f}  '\n",
    "          f'val_loss={val_loss:.4f}  val_acc={val_acc:.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot training history\n",
    "epochs_range = np.arange(1, epochs + 1)\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, sharex=True, figsize=(15, 7))\n",
    "\n",
    "ax1.plot(epochs_range, history['loss'],     'b',  label='Loss')\n",
    "ax1.plot(epochs_range, history['val_loss'], 'bo', label='Validation loss')\n",
    "ax1.set_title('Training and validation loss')\n",
    "ax1.legend()\n",
    "\n",
    "ax2.plot(epochs_range, history['accuracy'],     'b',  label='Accuracy')\n",
    "ax2.plot(epochs_range, history['val_accuracy'], 'bo', label='Validation accuracy')\n",
    "ax2.set_title('Training and validation accuracy')\n",
    "ax2.legend()\n",
    "\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Evaluate on Test Set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "overall_loss, overall_acc = run_epoch(test_loader, train=False)\n",
    "print(f'Overall loss     = {overall_loss:.4f}')\n",
    "print(f'Overall accuracy = {overall_acc:.4f}\\n')\n",
    "\n",
    "# Per-class accuracy\n",
    "model_metrics = util.calc_metrics(\n",
    "    cnn_model, test_input, y_test, int_to_vector_dict,\n",
    "    device=device, verbose=False\n",
    ")\n",
    "\n",
    "print(f'{\"Class ID\":<10}{\"Accuracy\":>13}')\n",
    "print('_' * 30)\n",
    "for cls, metrics in model_metrics.items():\n",
    "    print(f'{cls:>2d}{metrics[0][\"accuracy\"]:>18.4f}')\n",
    "    print('_' * 30)"
   ]
