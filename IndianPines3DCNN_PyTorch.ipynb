   "source": [
    "import numpy as np\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import DataLoader, TensorDataset\n",
    "import img_util_pyt as util\n",
    "from scipy import io as sio\n",
    "from matplotlib import pyplot as plt\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f'Using device: {device}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Dataset Loading"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "data_set shape: (145, 145, 200) | gt shape: (145, 145)\n"
     ]
    }
   ],
   "source": [
    "data_set = sio.loadmat('Indian_pines_corrected.mat').get('indian_pines_corrected')\n",
    "gt       = sio.loadmat('Indian_pines_gt.mat').get('indian_pines_gt')\n",
    "\n",
    "# data_set: (H, W, C) numpy array — channels-last, kept as-is for util functions\n",
    "# gt:       (H, W)   numpy array of int labels\n",
    "print('data_set shape:', data_set.shape, '| gt shape:', gt.shape)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Data Split"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Training samples : 7680\n",
      "Test samples     : 2568\n"
     ]
    }
   ],
   "source": [
    "train_fraction = 0.75\n",
    "rem_classes    = [0]\n",
    "\n",
    "(train_rows, train_cols), (test_rows, test_cols) = util.data_split(\n",
    "    gt,\n",
    "    train_fraction=train_fraction,\n",
    "    rem_classes=rem_classes\n",
    ")\n",
    "\n",
    "# util.data_split returns torch tensors — convert to numpy for gt indexing\n",
    "train_rows_np = train_rows.numpy()\n",
    "train_cols_np = train_cols.numpy()\n",
    "test_rows_np  = test_rows.numpy()\n",
    "test_cols_np  = test_cols.numpy()\n",
    "\n",
    "print(f'Training samples : {len(train_rows_np)}')\n",
    "print(f'Test samples     : {len(test_rows_np)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Sub-train samples : 7287\n",
      "Validation samples: 393\n"
     ]
    }
   ],
   "source": [
    "val_fraction = 0.05\n",
    "\n",
    "(train_rows_sub_t, train_cols_sub_t), (val_rows_t, val_cols_t) = util.val_split(\n",
    "    train_rows, train_cols, gt, val_fraction=val_fraction\n",
    ")\n",
    "\n",
    "train_rows_sub = train_rows_sub_t.numpy()\n",
    "train_cols_sub = train_cols_sub_t.numpy()\n",
    "val_rows       = val_rows_t.numpy()\n",
    "val_cols       = val_cols_t.numpy()\n",
    "\n",
    "print(f'Sub-train samples : {len(train_rows_sub)}')\n",
    "print(f'Validation samples: {len(val_rows)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Dimensionality Reduction (PCA)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Reduced data_set shape: (145, 145, 69)\n"
     ]
    }
   ],
   "source": [
    "data_set = util.reduce_dim(img_data=data_set, n_components=0.999)\n",
    "print('Reduced data_set shape:', data_set.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1500x700 with 10 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "fig, axes = plt.subplots(2, 5, sharex=True, sharey=True, figsize=(15, 7))\n",
    "for numb, axe in enumerate(axes.flat):\n",
    "    axe.imshow(data_set[:, :, numb])\n",
    "    axe.set_title('dim ' + str(numb))\n",
    "fig.subplots_adjust(wspace=0, hspace=0.2)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Rescale Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [],
   "source": [
    "data_set = util.rescale_data(data_set)   # default: 'standard' (z-score per band)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Build Patch Tensors\n",
    "\n",
    "- `patch_size=9` (larger than 2D case to give the 3D conv enough spectral context)\n",
    "- `create_patch` returns `(N, C, patch, patch)` channels-first arrays\n",
    "- An extra depth dimension is added: `(N, C, H, W)` → `(N, 1, C, H, W)` so\n",
    "  `nn.Conv3d` sees `(batch, in_channels=1, D=C, H=patch, W=patch)`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "train_input_sub : (7287, 1, 69, 9, 9) | y_train_sub : (7287, 16)\n",
      "val_input       : (393, 1, 69, 9, 9) | y_val       : (393, 16)\n",
      "test_input      : (2568, 1, 69, 9, 9) | y_test      : (2568, 16)\n"
     ]
    }
   ],
   "source": [
    "patch_size = 9\n",
    "\n",
    "catg_labels        = np.unique([int(gt[r, c]) for r, c in zip(train_rows_np, train_cols_np)])\n",
    "int_to_vector_dict = util.label_2_one_hot(catg_labels)\n",
    "\n",
    "train_input_sub, y_train_sub = util.create_patch(\n",
    "    data_set, gt, (train_rows_sub, train_cols_sub),\n",
    "    patch_size=patch_size, label_vect_dict=int_to_vector_dict\n",
    ")\n",
    "\n",
    "val_input, y_val = util.create_patch(\n",
    "    data_set, gt, (val_rows, val_cols),\n",
    "    patch_size=patch_size, label_vect_dict=int_to_vector_dict\n",
    ")\n",
    "\n",
    "test_input, y_test = util.create_patch(\n",
    "    data_set, gt, (test_rows_np, test_cols_np),\n",
    "    patch_size=patch_size, label_vect_dict=int_to_vector_dict\n",
    ")\n",
    "\n",
    "# create_patch gives (N, C, H, W); Conv3d needs (N, 1, C, H, W)\n",
    "# axis=1 inserts the depth dim right after batch, keeping C as the 3D 'depth'\n",
    "train_input_sub = np.expand_dims(train_input_sub, axis=1)   # (N,1,C,H,W)\n",
    "val_input       = np.expand_dims(val_input,       axis=1)\n",
    "test_input      = np.expand_dims(test_input,      axis=1)\n",
    "\n",
    "print('train_input_sub :', train_input_sub.shape, '| y_train_sub :', y_train_sub.shape)\n",
    "print('val_input       :', val_input.shape,       '| y_val       :', y_val.shape)\n",
    "print('test_input      :', test_input.shape,      '| y_test      :', y_test.shape)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. PyTorch DataLoaders"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {},
   "outputs": [],
   "source": [
    "batch_size = 2**5   # 32\n",
    "\n",
    "def make_loader(X, y, shuffle=True):\n",
    "    X_t = torch.tensor(X, dtype=torch.float32)\n",
    "    y_t = torch.tensor(y, dtype=torch.float32)\n",
    "    return DataLoader(TensorDataset(X_t, y_t), batch_size=batch_size, shuffle=shuffle)\n",
    "\n",
    "train_loader = make_loader(train_input_sub, y_train_sub, shuffle=True)\n",
    "val_loader   = make_loader(val_input,       y_val,       shuffle=False)\n",
    "test_loader  = make_loader(test_input,      y_test,      shuffle=False)"
   ]
  },
  {
